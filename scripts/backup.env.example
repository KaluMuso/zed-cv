# Copy to /etc/zedapply/backup.env on the OCI VM (chmod 600, root-owned).
# Sourced by backup_database.sh, restore_database.sh, test_backup_restore.sh.

# Supabase direct Postgres URI (Dashboard → Project Settings → Database → Connection string → URI).
# Use the pooler-disabled direct host for pg_dump (port 5432), not the transaction pooler.
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# 32+ byte secret for openssl enc -aes-256-cbc (generate: openssl rand -base64 32)
BACKUP_ENCRYPTION_KEY=

# OCI Object Storage
OCI_BACKUP_BUCKET=zedapply-backups
# OCI_CLI_CONFIG_FILE=/home/ubuntu/.oci/config   # user API key auth (default)
# OCI_CLI_AUTH=instance_principal                 # uncomment on OCI compute with dynamic group

# Optional overrides
# BACKUP_LOG_FILE=/var/log/zedapply-backup.log
# BACKUP_TMP_DIR=/tmp/zedapply-backup
# OCI_BACKUP_PREFIX=zedapply

# Weekly test-restore (disposable staging Supabase project only)
# STAGING_SUPABASE_DB_URL=postgresql://postgres.[STAGING_REF]:[PASSWORD]@db.[STAGING_REF].supabase.co:5432/postgres

# WAHA alert when test-restore fails (same values as n8n-docker .env)
# WAHA_API_URL=http://127.0.0.1:3000
# WAHA_API_KEY=
# ADMIN_ALERT_PHONE=+260761359005
