# ─── ZedApply Frontend — Environment Variables ───
# Set these in Vercel Dashboard → Settings → Environment Variables

# API base URL (your Oracle Cloud backend)
NEXT_PUBLIC_API_URL=https://api.zedcv.com/api/v1

# Supabase (for client-side auth if needed)
NEXT_PUBLIC_SUPABASE_URL=https://chnesgmcuxyhwhzomdov.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Sentry (error reporting + tracing) ───
# Leave NEXT_PUBLIC_SENTRY_DSN blank to disable Sentry entirely; the
# instrumentation, next.config wrapping, and SDK init all short-circuit
# when the DSN is empty so local dev stays untouched.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Overrides NEXT_PUBLIC_SENTRY_ENVIRONMENT on the server runtime only
# (not inlined into the client bundle). Use to tag Vercel preview
# builds without exposing the value to browsers.
SENTRY_ENVIRONMENT=
# Build-time credentials for source-map upload. Required only on the
# CI/Vercel build, NOT in the runtime env. Generate the auth token in
# https://convergeo-w2.sentry.io/settings/account/api/auth-tokens/
# with the `project:releases` and `org:read` scopes.
SENTRY_ORG=convergeo-w2
SENTRY_PROJECT=zedcv-frontend
SENTRY_AUTH_TOKEN=
