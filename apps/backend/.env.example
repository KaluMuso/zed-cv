# ─── Zed CV Backend — Environment Variables ───

# ── Supabase ──
SUPABASE_URL=https://chnesgmcuxyhwhzomdov.supabase.co
SUPABASE_KEY=              # service_role key from Dashboard → Settings → API

# ── AI: Embeddings (Google Gemini) ──
GEMINI_API_KEY=            # aistudio.google.com/app/apikey

# ── AI: LLM via OpenRouter ──
OPENROUTER_API_KEY=        # openrouter.ai/keys

# ── Payments: DPO Pay ──
DPO_PAY_COMPANY_TOKEN=
DPO_PAY_SERVICE_TYPE=

# ── Payments: Lenco (optional — leave blank until ready) ──
# Sandbox base URL is v2; prod is api.lenco.co/access/v2. The frontend
# also needs NEXT_PUBLIC_LENCO_PUBLIC_KEY (the `pub-...` key) for the
# in-browser widget — that goes in Vercel env, not here.
LENCO_API_KEY=
LENCO_PUBLIC_KEY=
LENCO_API_URL=https://sandbox.lenco.co/access/v2
LENCO_ENVIRONMENT=sandbox
LENCO_VERIFY_SIGNATURES=true
# sha256(LENCO_API_KEY).hexdigest() — required when LENCO_ENVIRONMENT=production
LENCO_WEBHOOK_SECRET=

# ── WhatsApp (WAHA) ──
WAHA_API_URL=http://localhost:3001
WAHA_API_KEY=
WAHA_WEBHOOK_SECRET=
# Track 4c: channel job scraper (separate from OTP /user webhook)
WHATSAPP_SCRAPE_CHANNELS=
WHATSAPP_SCRAPER_WEBHOOK_TOKEN=
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
WAHA_SESSION_NAME=default
# Admin ops alerts (review queue → WhatsApp). Set false to disable sends.
ENABLE_ADMIN_WHATSAPP_ALERTS=true
ADMIN_ALERT_PHONE=+260761359005
# Bwana chat: optional n8n webhook (empty = in-process FAQ/LLM on backend)
BWANA_N8N_WEBHOOK_URL=
BWANA_ESCALATION_PHONE=+260761359005
# Legacy single-channel ingest on /webhooks/whatsapp (optional)
WHATSAPP_CHANNEL_JOBS_ID=
WHATSAPP_JOBS_INGEST_ENABLED=false

# ── Auth ──
JWT_SECRET=                # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Superadmin (your phone number gets unrestricted access) ──
SUPERADMIN_PHONE=+260      # Your full +260 number

# ── App ──
DEBUG=true

# ── Observability: Sentry (optional — leave blank to disable) ──
SENTRY_DSN=                       # https://...@...ingest.de.sentry.io/...
SENTRY_ENVIRONMENT=development    # production / staging / development

# ── Email (Resend) — OTP + digests + contact relay ──
# Sender domain must be verified in Resend (vergeo.company). zedcv.com is NOT verified.
RESEND_API_KEY=            # resend.com/api-keys
RESEND_FROM_EMAIL=Zed CV <info@vergeo.company>
# Optional: published template id/alias for daily digests (see email.py)
RESEND_DAILY_DIGEST_TEMPLATE_ID=daily-job-matches
CONTACT_EMAIL=convergeozambia@gmail.com
APP_URL=https://zedcv.com

# ── Rate limiter storage (optional — leave blank for in-memory) ──
# When set, slowapi shares rate-limit state across replicas and survives
# `docker compose up -d --force-recreate`. Without it, every container
# restart resets all IP budgets, which lets a bot replay attacks fresh.
# Free option: Upstash Redis Serverless (10k commands/day, no card needed)
#   1. Create a database at https://console.upstash.com
#   2. Copy the "Redis CLI Connect" URL (rediss://default:<token>@<host>:6379)
#   3. Paste here and force-recreate the backend container
REDIS_URL=

# ── Web Push (VAPID) — high-match browser alerts ──
# Generate once: cd apps/backend && python3 scripts/generate_vapid_keys.py
# Public key also goes to Vercel as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=convergeozambia@gmail.com
