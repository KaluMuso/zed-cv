# ─── Zed CV Backend — Production Environment ───
# Copy this to .env and fill in real values before deploying.

# ── Supabase ──
SUPABASE_URL=https://chnesgmcuxyhwhzomdov.supabase.co
SUPABASE_KEY=              # Dashboard → Settings → API → service_role (KEEP SECRET)

# ── AI: Embeddings (Google Gemini — free tier!) ──
GEMINI_API_KEY=            # aistudio.google.com/app/apikey

# ── AI: LLM via OpenRouter (gemini-flash-2.0) ──
OPENROUTER_API_KEY=        # openrouter.ai/keys

# ── Payments: DPO Pay (Mobile Money) ──
DPO_PAY_COMPANY_TOKEN=     # From DPO Pay merchant dashboard
DPO_PAY_SERVICE_TYPE=      # Service type ID from DPO Pay

# ── Payments: Lenco (optional — add when ready) ──
LENCO_API_KEY=
LENCO_PUBLIC_KEY=
LENCO_API_URL=https://api.lenco.co/access/v2
LENCO_ENVIRONMENT=production
LENCO_VERIFY_SIGNATURES=true
LENCO_WEBHOOK_SECRET=

# ── WhatsApp (WAHA) ──
WAHA_API_URL=http://waha:3000   # Docker network name in production
WAHA_API_KEY=                    # Strong random string, same in docker-compose
ENABLE_ADMIN_WHATSAPP_ALERTS=true
ADMIN_ALERT_PHONE=+260761359005

# ── Auth ──
JWT_SECRET=                # Generate on Windows: python -c "import secrets; print(secrets.token_hex(32))"

# ── Superadmin ──
SUPERADMIN_PHONE=+260      # Your phone number — gets unlimited access

# ── Email (Resend) — OTP + digests; domain must be verified in Resend dashboard ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zed CV <info@vergeo.company>
RESEND_DAILY_DIGEST_TEMPLATE_ID=daily-job-matches
CONTACT_EMAIL=convergeozambia@gmail.com
APP_URL=https://zedcv.com

# ── App Settings ──
DEBUG=false

# ── Observability: Sentry (recommended for production) ──
SENTRY_DSN=                       # https://...@...ingest.de.sentry.io/... (Sentry → Settings → Client Keys)
SENTRY_ENVIRONMENT=production
