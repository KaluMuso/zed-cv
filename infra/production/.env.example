# Compose-level variable substitutions for infra/production/docker-compose.prod.yml.
# Copy this file to .env in the same directory and fill in real values
# before running `docker compose -f docker-compose.prod.yml up -d`.
#
# Compose only reads `.env` in this directory (or via --env-file); it does
# NOT inherit from apps/backend/.env. See the header comment at the top
# of docker-compose.prod.yml for the full reasoning.

# Strong random string. Must match what the backend reads from
# apps/backend/.env (also WAHA_API_KEY). docker-compose maps this into
# the WAHA container as WHATSAPP_API_KEY (WAHA's own env var name).
WAHA_API_KEY=

# n8n basic-auth credentials for the workflow editor.
N8N_USER=
N8N_PASSWORD=

# Same Supabase project as the backend uses. Service role key (not anon),
# because n8n writes to tables that have RLS enabled.
SUPABASE_URL=
SUPABASE_KEY=
