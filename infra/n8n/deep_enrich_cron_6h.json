{
  "name": "Zed CV - Deep Enrich Cron Every 6h",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 6 }] } },
      "name": "Every 6 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FASTAPI_URL }}/api/v1/jobs/deep-enrich-tick?limit=50",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "INGEST_API_KEY", "value": "={{ $env.INGEST_API_KEY }}" }]
        }
      },
      "name": "Run Deep Enrich Tick",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    }
  ],
  "connections": {
    "Every 6 Hours": { "main": [[{ "node": "Run Deep Enrich Tick", "type": "main", "index": 0 }]] }
  }
}
