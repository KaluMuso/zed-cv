# ~/n8n-docker-staging/.env — staging backend + WAHA (never commit real values)
#
# Copy: cp infra/staging/.env.example ~/n8n-docker-staging/.env

# ── Supabase (staging project only — NOT chnesgmcuxyhwhzomdov) ──
SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
SUPABASE_KEY=

# ── AI ──
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Auth ──
JWT_SECRET=

# ── Payments (sandbox only on staging) ──
LENCO_API_KEY=
LENCO_PUBLIC_KEY=
LENCO_API_URL=https://sandbox.lenco.co/access/v2
DPO_PAY_COMPANY_TOKEN=
DPO_PAY_SERVICE_TYPE=

# ── WhatsApp (isolated session; keep unpaired or use a burner) ──
WAHA_API_KEY=
WAHA_WEBHOOK_SECRET=
WAHA_SESSION_NAME=default-staging
ENABLE_ADMIN_WHATSAPP_ALERTS=false

# ── Email (disable or use a staging-only Resend key/domain) ──
RESEND_API_KEY=
# Optional: omit RESEND_API_KEY and leave outbound email disabled in code paths

# ── Observability ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
ENVIRONMENT=staging

# ── CORS / app URLs ──
CORS_ALLOWED_ORIGINS=https://preview.zedapply.com,http://localhost:3000
APP_URL=https://preview.zedapply.com

# ── Ingest (optional — leave empty unless testing scraper ingest on staging) ──
INGEST_API_KEY=
ADMIN_API_KEY=

# ── Compose-level WAHA key (same value as WAHA_API_KEY above) ──
# Used by docker-compose variable substitution for waha-staging service.
